# --- Compose project ---
COMPOSE_PROJECT_NAME=scout

# --- PHP / App ---
APP_PORT=8080
APP_ENV=dev
# Leave blank to always install the latest stable Symfony release.
# Set to e.g. "7.4" to pin to a specific minor/LTS line instead.
SYMFONY_VERSION=

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=scout
MYSQL_USER=scout
MYSQL_PASSWORD=change_me
MYSQL_PORT=3306

# --- Redis ---
REDIS_PORT=6379
